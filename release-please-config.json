{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "draft": true,
  "draft-pull-request": true,
  "force-tag-creation": true,
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "include-v-in-tag": true,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Added"
        },
        {
          "type": "fix",
          "section": "Fixed"
        },
        {
          "type": "perf",
          "section": "Changed"
        },
        {
          "type": "refactor",
          "section": "Changed"
        },
        {
          "type": "deps",
          "section": "Changed"
        }
      ]
    }
  }
}
